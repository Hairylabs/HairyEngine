{
  "name": "hairyengine",
  "version": "0.0.23",
  "private": true,
  "description": "HairyEngine — desktop Three.js scene editor with Claude + Blender MCP integration",
  "author": "Hairylabs",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node scripts/run.js dev",
    "build": "node scripts/run.js build",
    "preview": "node scripts/run.js preview",
    "package": "node scripts/run.js build && electron-builder --win --x64",
    "package:dir": "node scripts/run.js build && electron-builder --win --x64 --dir",
    "release": "node scripts/release.js",
    "web:build": "vite build --config vite.web.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.139",
    "@dimforge/rapier3d-compat": "^0.19.3",
    "@geckos.io/client": "^3.1.0",
    "colyseus.js": "^0.16.22",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "three": "^0.171.0",
    "three-bvh-csg": "^0.0.18",
    "three-mesh-bvh": "^0.9.9",
    "viem": "^2.48.11",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/three": "^0.171.0",
    "cross-env": "^7.0.3",
    "electron": "^33.3.2",
    "electron-builder": "^25.1.8",
    "electron-vite": "^4.0.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  },
  "build": {
    "appId": "com.hairylabs.hairyengine",
    "productName": "HairyEngine",
    "asar": true,
    "npmRebuild": false,
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "HairyEngine",
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "HairyEngine-${version}-portable.exe"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Hairylabs",
        "repo": "HairyEngine",
        "private": false,
        "releaseType": "release"
      }
    ]
  }
}
